# Environment configuration template for the ONDEWO SIP Python client examples.
#
# This is a NON-SECRET template. Copy the placeholder values below and replace them with
# your deployment's real values before running an example. Every example loads this file
# via python-dotenv (path relative to the script), so `cwd` does not matter.
#
# Canonical variable scheme — one name per concept, reused across every ONDEWO SDK example.

# --- Connection -------------------------------------------------------------------------
ONDEWO_HOST=localhost
ONDEWO_PORT=50099

# --- Secure channel ---------------------------------------------------------------------
# ONDEWO_USE_SECURE_CHANNEL: true/false — open a TLS gRPC channel.
# ONDEWO_GRPC_CERT: optional path to a PEM cert file used for the secure channel.
ONDEWO_USE_SECURE_CHANNEL=false
ONDEWO_GRPC_CERT=

# --- Basic auth / SDK technical user ----------------------------------------------------
ONDEWO_USER_NAME=tech-user@example.com
ONDEWO_PASSWORD=change-me

# --- Keycloak headless offline-token auth (D18) -----------------------------------------
# Set the three fields together to use the Keycloak offline-token flow; leave them empty
# to attach no auth token (e.g. plaintext server or an Envoy ingress that injects auth).
KEYCLOAK_URL=https://my-host/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-sip-cai-sdk-public

# --- SIP service-specific ---------------------------------------------------------------
# The SIP account to register plus the address to place a call to.
ONDEWO_SIP_ACCOUNT_NAME=name@domain.com
ONDEWO_SIP_ACCOUNT_PASSWORD=change-me
ONDEWO_SIP_CALLEE_ADDRESS=callee
